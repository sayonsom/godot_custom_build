[gd_scene load_steps=4 format=3 uid="uid://house_main"]

[ext_resource type="Script" path="res://main.gd"          id="1_main"]
[ext_resource type="Script" path="res://floorplan_draw.gd" id="2_fp"]
[ext_resource type="Script" path="res://orbit_camera.gd"  id="3_cam"]

; ══════════════════════════════════════════════════════════════════════════════
[node name="Main" type="Node"]
script = ExtResource("1_main")

; ── 3D scene (full-screen behind UI) ─────────────────────────────────────────
[node name="Scene3D" type="Node3D" parent="."]

[node name="DirectionalLight3D" type="DirectionalLight3D" parent="Scene3D"]
transform = Transform3D(0.866, -0.354, 0.354, 0, 0.707, 0.707, -0.5, -0.612, 0.612, 0, 12, 0)
light_energy = 1.0
shadow_enabled = true

[node name="Camera3D" type="Camera3D" parent="Scene3D"]
script = ExtResource("3_cam")
current = true
fov = 50.0

; ══════════════════════════════════════════════════════════════════════════════
; UI overlay
; ══════════════════════════════════════════════════════════════════════════════
[node name="UI" type="CanvasLayer" parent="."]

[node name="Root" type="Control" parent="UI"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

; ── Top bar: "< My home" ─────────────────────────────────────────────────────
[node name="TopBar" type="PanelContainer" parent="UI/Root"]
layout_mode = 1
anchor_right = 1.0
offset_bottom = 60
grow_horizontal = 2

[node name="TopHBox" type="HBoxContainer" parent="UI/Root/TopBar"]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8
offset_left = 8
offset_right = -8

[node name="BackBtn" type="Button" parent="UI/Root/TopBar/TopHBox"]
layout_mode = 2
custom_minimum_size = Vector2(44, 44)
text = "‹"
theme_override_font_sizes/font_size = 24
flat = true

[node name="TitleLabel" type="Label" parent="UI/Root/TopBar/TopHBox"]
layout_mode = 2
size_flags_horizontal = 3
text = "My home"
theme_override_font_sizes/font_size = 20

[node name="MenuBtn" type="Button" parent="UI/Root/TopBar/TopHBox"]
layout_mode = 2
custom_minimum_size = Vector2(44, 44)
text = "⋮"
theme_override_font_sizes/font_size = 22
flat = true

; ── 2D floor plan view (fills area when in 2D mode) ──────────────────────────
[node name="View2D" type="Control" parent="UI/Root"]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
anchor_top = 0.0
offset_top = 60
offset_bottom = -70
grow_horizontal = 2
grow_vertical = 2
visible = false
script = ExtResource("2_fp")
mouse_filter = 2

; ── Bottom bar: SmartThings-style controls ────────────────────────────────────
[node name="BottomBar" type="PanelContainer" parent="UI/Root"]
layout_mode = 1
anchor_top = 1.0
anchor_bottom = 1.0
anchor_right = 1.0
offset_top = -70
grow_horizontal = 2
grow_vertical = 0

[node name="BtnRow" type="HBoxContainer" parent="UI/Root/BottomBar"]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
alignment = 1
theme_override_constants/separation = 12
offset_left = 12
offset_right = -12

[node name="BtnFloor" type="Button" parent="UI/Root/BottomBar/BtnRow"]
layout_mode = 2
custom_minimum_size = Vector2(90, 46)
text = "1F  ▲"
theme_override_font_sizes/font_size = 15

[node name="BtnDevices" type="Button" parent="UI/Root/BottomBar/BtnRow"]
layout_mode = 2
custom_minimum_size = Vector2(140, 46)
text = "All devices  ▲"
theme_override_font_sizes/font_size = 15

[node name="BtnSpacer" type="Control" parent="UI/Root/BottomBar/BtnRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Btn3D" type="Button" parent="UI/Root/BottomBar/BtnRow"]
layout_mode = 2
custom_minimum_size = Vector2(52, 46)
text = "2D"
theme_override_font_sizes/font_size = 15
tooltip_text = "Switch between 3D map and 2D floor plan"

[node name="BtnReset" type="Button" parent="UI/Root/BottomBar/BtnRow"]
layout_mode = 2
custom_minimum_size = Vector2(52, 46)
text = "↺"
theme_override_font_sizes/font_size = 20
tooltip_text = "Reset camera rotation"
